---
import "../assets/globals.css";

const basePath = Astro.locals.runtime?.env?.ASSETS_PREFIX || "/app";
const pathname = Astro.url?.pathname || "";
const isLogin = pathname === `${basePath}/login`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>BRND WGN Object Storage</title>
	</head>
	<body>
		{!isLogin ? (
			<header class="w-full border-b border-base-300 bg-base-100/80 backdrop-blur">
				<div class="container mx-auto max-w-6xl px-4 sm:px-6 py-3 flex items-center justify-between">
					<div class="font-semibold tracking-tight">Object Storage</div>
					<nav class="flex items-center gap-2">
						<form method="get" action={`${basePath}/api/logout`}>
							<button type="submit" class="btn btn-outline btn-sm">
								Logout
							</button>
						</form>
					</nav>
				</div>
			</header>
		) : null}

		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>

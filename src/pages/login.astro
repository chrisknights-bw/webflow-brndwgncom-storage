---
import Layout from "../layouts/Layout.astro";

const basePath = Astro.locals.runtime?.env?.ASSETS_PREFIX || "/app";
const next = Astro.url.searchParams.get("next") || `${basePath}/`;
const error = Astro.url.searchParams.get("error");

const runtimeEnvLogo = Astro.locals.runtime?.env?.LOGO as string | undefined;
const logoSrc =
	(runtimeEnvLogo || import.meta.env.LOGO || process.env.LOGO || "").trim() || undefined;
const buttonColor = (Astro.locals.runtime?.env?.BUTTON_COLOR as string | undefined) || "#111827";
const buttonTextColor = (Astro.locals.runtime?.env?.BUTTON_TEXT_COLOR as string | undefined) || "#ffffff";
---

<Layout title="Login">
	<div class="min-h-screen flex items-center justify-center px-6 py-14 sm:px-10 sm:py-20 bg-[#eeeeee]">
		<div class="w-full max-w-md">
			{logoSrc ? (
				<div class="flex justify-center mb-8">
					<img
						src={logoSrc}
						alt="Logo"
						class="max-h-20 sm:max-h-24 w-auto object-contain"
						loading="eager"
						decoding="async"
					/>
				</div>
			) : null}

		<div class="card w-full bg-[#e5e7eb] shadow-none border border-black/10">
			<div class="card-body p-8 sm:p-10">
				<h1 class="text-2xl font-bold">Sign in</h1>
				<p class="text-sm text-base-content/70 mt-1">Log in to access the file uploader.</p>

				{error ? (
					<div class="alert alert-error mt-4">
						<span>Invalid username or password.</span>
					</div>
				) : null}

				<form method="post" action={`${basePath}/api/login`} class="mt-6 space-y-4">
					<input type="hidden" name="next" value={next} />

					<div class="form-control">
						<label class="label" for="username">
							<span class="label-text">Username</span>
						</label>
						<input
							id="username"
							name="username"
							type="text"
							class="input input-bordered w-full bg-white text-black"
							autocomplete="username"
							required
						/>
					</div>

					<div class="form-control">
						<label class="label" for="password">
							<span class="label-text">Password</span>
						</label>
						<input
							id="password"
							name="password"
							type="password"
							class="input input-bordered w-full bg-white text-black"
							autocomplete="current-password"
							required
						/>
					</div>

					<button
						type="submit"
						class="btn w-full border-0 mt-2"
						style={`background-color: ${buttonColor}; color: ${buttonTextColor};`}
					>
						Login
					</button>
				</form>

				<div class="mt-6 text-xs text-base-content/60">
					<form method="get" action={`${basePath}/api/logout`}>
						<button class="link link-hover" type="submit">Need to switch accounts? Logout</button>
					</form>
				</div>
			</div>
		</div>
		</div>
	</div>
</Layout>
